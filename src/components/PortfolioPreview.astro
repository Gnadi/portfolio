---
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';
import Pill from './Pill.astro';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data } = Astro.props.project;
const initial = data.title.trim().charAt(0).toUpperCase();
const statusLabel = data.status === 'live' ? 'Live' : data.status === 'preview' ? 'Preview' : null;
---
<a class:list={['card', { preview: data.status === 'preview' }]} href={data.url} target="_blank" rel="noreferrer">
	<div class="initial" aria-hidden="true">{initial}</div>
	<div class="meta">
		{statusLabel && <Pill>{statusLabel}</Pill>}
		<span class="external"><Icon icon="external" size="1.2em" /></span>
	</div>
	<h3 class="title">{data.title}</h3>
	<p class="description">{data.description}</p>
</a>
<style>
	.card {
		display: grid;
		grid-template-columns: auto 1fr;
		grid-template-rows: auto 1fr auto;
		gap: 0.75rem 1rem;
		min-height: 11rem;
		padding: 1rem;
		background: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		color: var(--gray-200);
		font-family: var(--font-brand);
		transition: box-shadow var(--theme-transition), transform var(--theme-transition);
	}

	.card:hover,
	.card:focus-visible {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.initial {
		grid-row: 1 / 2;
		grid-column: 1 / 2;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 0.5rem;
		background: var(--accent-regular);
		color: var(--accent-text-over);
		font-size: 1.5rem;
		font-weight: 700;
		line-height: 1;
	}

	.card.preview .initial {
		background: var(--gray-700);
		color: var(--gray-100);
	}

	.meta {
		grid-row: 1 / 2;
		grid-column: 2 / 3;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.5rem;
	}

	.external {
		display: inline-flex;
		color: var(--gray-300);
	}

	.title {
		grid-row: 2 / 3;
		grid-column: 1 / 3;
		align-self: end;
		margin: 0;
		font-size: var(--text-lg);
		font-weight: 600;
		color: var(--gray-0);
	}

	.description {
		grid-row: 3 / 4;
		grid-column: 1 / 3;
		margin: 0;
		font-size: var(--text-sm);
		line-height: 1.4;
		color: var(--gray-300);
	}

	@media (min-width: 50em) {
		.card {
			min-height: 16rem;
			padding: 1.5rem;
			border-radius: 1.5rem;
			gap: 1rem 1.25rem;
		}

		.initial {
			width: 3.5rem;
			height: 3.5rem;
			font-size: 1.875rem;
			border-radius: 0.75rem;
		}

		.title {
			font-size: var(--text-xl);
		}

		.description {
			font-size: var(--text-md);
		}
	}
</style>
