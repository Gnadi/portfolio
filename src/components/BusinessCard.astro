---
import Icon from './Icon.astro';
---

<div class="bc-scene">
	<!-- Layered background: photo + gradient veil -->
	<div class="bc-bg-photo" aria-hidden="true"></div>
	<div class="bc-bg-veil" aria-hidden="true"></div>

	<!-- Headline (left side, Trade Republic style) -->
	<div class="bc-headline">
		<span class="bc-label">Backend Engineer</span>
		<h2 class="bc-name">Johannes<br />Gnadlinger</h2>
		<p class="bc-company">Raiffeisen Software GmbH</p>
		<p class="bc-location">📍 Linz, Austria</p>
	</div>

	<!-- Frosted glass business card (right side) -->
	<div class="bc-card" id="bc-card" aria-label="Business card – contact details">
		<div class="bc-card-inner">
			<!-- Card header row -->
			<div class="bc-card-top">
				<div class="bc-monogram" aria-hidden="true">JG</div>
				<span class="bc-card-tag">BUSINESS CARD</span>
			</div>

			<!-- Contact links -->
			<ul class="bc-links" role="list">
				<li>
					<a href="mailto:johannes.gnadlinger1997@gmail.com" class="bc-link">
						<Icon icon="paper-plane-tilt" size="1.1em" />
						<span>johannes.gnadlinger1997@gmail.com</span>
					</a>
				</li>
				<li>
					<a href="https://github.com/Gnadi" class="bc-link" target="_blank" rel="noopener noreferrer">
						<Icon icon="github-logo" size="1.1em" />
						<span>github.com/Gnadi</span>
					</a>
				</li>
				<li>
					<a href="https://at.linkedin.com/in/johannes-gnadlinger-842293271" class="bc-link" target="_blank" rel="noopener noreferrer">
						<Icon icon="linkedin-logo" size="1.1em" />
						<span>LinkedIn</span>
					</a>
				</li>
				<li>
					<a href="https://cv.gnadlinger.me/" class="bc-link" target="_blank" rel="noopener noreferrer">
						<Icon icon="external" size="1.1em" />
						<span>cv.gnadlinger.me</span>
					</a>
				</li>
				<li>
					<a href="https://blog.gnadlinger.me/" class="bc-link" target="_blank" rel="noopener noreferrer">
						<Icon icon="pencil-line" size="1.1em" />
						<span>blog.gnadlinger.me</span>
					</a>
				</li>
				<li>
					<a href="https://stackoverflow.com/users/6504152/johannes-gnadlinger" class="bc-link" target="_blank" rel="noopener noreferrer">
						<Icon icon="stackoverflow-logo" size="1.1em" />
						<span>Stack Overflow</span>
					</a>
				</li>
			</ul>

			<!-- Card footer -->
			<div class="bc-card-bottom">
				<span class="bc-card-url">gnadlinger.me</span>
			</div>
		</div>

		<!-- Dynamic shine / reflection overlay -->
		<div class="bc-shine" id="bc-shine" aria-hidden="true"></div>
	</div>
</div>

<script>
	const card = document.getElementById('bc-card') as HTMLElement | null;
	const shine = document.getElementById('bc-shine') as HTMLElement | null;
	const scene = card?.closest<HTMLElement>('.bc-scene') ?? null;

	if (card && scene) {
		let rafId = 0;
		let isHovering = false;

		function setTilt(rotX: number, rotY: number, shineX: number, shineY: number) {
			card!.style.transform =
				`perspective(1000px) rotateZ(-8deg) rotateX(${rotX}deg) rotateY(${rotY}deg)`;
			if (shine) {
				shine.style.background =
					`radial-gradient(ellipse at ${shineX}% ${shineY}%, rgba(255,255,255,0.2) 0%, transparent 65%)`;
			}
		}

		scene.addEventListener('mousemove', (e: MouseEvent) => {
			if (!isHovering) {
				isHovering = true;
				card!.style.animationPlayState = 'paused';
			}
			cancelAnimationFrame(rafId);
			rafId = requestAnimationFrame(() => {
				const rect = scene.getBoundingClientRect();
				const dx = (e.clientX - (rect.left + rect.width / 2)) / (rect.width / 2);
				const dy = (e.clientY - (rect.top + rect.height / 2)) / (rect.height / 2);
				setTilt(dy * -10, dx * 12, ((dx + 1) / 2) * 100, ((dy + 1) / 2) * 100);
			});
		});

		scene.addEventListener('mouseleave', () => {
			isHovering = false;
			cancelAnimationFrame(rafId);
			card!.style.animationPlayState = 'running';
			card!.style.transform = '';
			if (shine) shine.style.background = '';
		});

		scene.addEventListener('touchmove', (e: TouchEvent) => {
			const touch = e.touches[0];
			const rect = scene.getBoundingClientRect();
			const dx = (touch.clientX - (rect.left + rect.width / 2)) / (rect.width / 2);
			const dy = (touch.clientY - (rect.top + rect.height / 2)) / (rect.height / 2);
			setTilt(dy * -6, dx * 8, ((dx + 1) / 2) * 100, ((dy + 1) / 2) * 100);
		}, { passive: true });

		scene.addEventListener('touchend', () => {
			card!.style.transform = '';
			if (shine) shine.style.background = '';
		});
	}
</script>

<style>
	/* ── Scene ──────────────────────────────────────────── */
	.bc-scene {
		position: relative;
		width: 100%;
		min-height: 560px;
		border-radius: 1.5rem;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: space-between;
		gap: 2.5rem;
		padding: 3rem 2.5rem;
	}

	/* ── Background photo ───────────────────────────────── */
	.bc-bg-photo {
		position: absolute;
		inset: 0;
		background-image: url('/assets/about.jpg');
		background-size: cover;
		background-position: center 20%;
		z-index: 0;
	}

	.bc-bg-veil {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			140deg,
			rgba(28, 0, 86, 0.88) 0%,
			rgba(118, 17, 166, 0.62) 55%,
			rgba(28, 0, 86, 0.78) 100%
		);
		z-index: 1;
	}

	/* ── Headline ───────────────────────────────────────── */
	.bc-headline {
		position: relative;
		z-index: 3;
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		color: #fff;
	}

	.bc-label {
		font-size: var(--text-base);
		color: rgba(255, 255, 255, 0.55);
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.bc-name {
		font-family: var(--font-brand);
		font-size: clamp(2.5rem, 7vw, 4rem);
		font-weight: 700;
		line-height: 1.05;
		color: #fff;
		margin: 0.2rem 0 0;
	}

	.bc-company {
		margin-top: 0.75rem;
		font-size: var(--text-md);
		color: rgba(255, 255, 255, 0.7);
	}

	.bc-location {
		font-size: var(--text-md);
		color: rgba(255, 255, 255, 0.55);
	}

	/* ── Glass card ─────────────────────────────────────── */
	.bc-card {
		position: relative;
		z-index: 4;
		align-self: center;
		width: min(380px, 92%);
		aspect-ratio: 1.586 / 1;
		background: rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(20px) saturate(160%);
		-webkit-backdrop-filter: blur(20px) saturate(160%);
		border: 1px solid rgba(255, 255, 255, 0.25);
		border-radius: 1.25rem;
		box-shadow:
			0 20px 60px rgba(0, 0, 0, 0.5),
			inset 0 1px 0 rgba(255, 255, 255, 0.38),
			inset 0 -1px 0 rgba(255, 255, 255, 0.08);
		overflow: hidden;
		animation: bc-float 5.5s ease-in-out infinite;
		will-change: transform;
		cursor: default;
	}

	@keyframes bc-float {
		0%, 100% {
			transform: perspective(1200px) rotateZ(-8deg) translateY(0px);
		}
		50% {
			transform: perspective(1200px) rotateZ(-8deg) translateY(-16px);
		}
	}

	/* ── Card inner ─────────────────────────────────────── */
	.bc-card-inner {
		position: relative;
		z-index: 1;
		height: 100%;
		padding: 1.4rem 1.75rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		color: #fff;
	}

	.bc-card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.bc-monogram {
		width: 2.75rem;
		height: 2.75rem;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.18);
		border: 1px solid rgba(255, 255, 255, 0.38);
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 700;
		letter-spacing: 0.04em;
		color: #fff;
	}

	.bc-card-tag {
		font-size: var(--text-sm);
		letter-spacing: 0.14em;
		color: rgba(255, 255, 255, 0.45);
		text-transform: uppercase;
	}

	/* ── Links grid ─────────────────────────────────────── */
	.bc-links {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.55rem 1.25rem;
	}

	.bc-link {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		font-size: var(--text-sm);
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
		transition: color 0.15s;
		white-space: nowrap;
		overflow: hidden;
	}

	.bc-link span {
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.bc-link:hover {
		color: #fff;
	}

	/* ── Card bottom ────────────────────────────────────── */
	.bc-card-bottom {
		display: flex;
		justify-content: flex-end;
	}

	.bc-card-url {
		font-size: var(--text-sm);
		letter-spacing: 0.06em;
		color: rgba(255, 255, 255, 0.42);
	}

	/* ── Shine overlay ──────────────────────────────────── */
	.bc-shine {
		position: absolute;
		inset: 0;
		z-index: 2;
		pointer-events: none;
		transition: background 0.12s ease-out;
	}

	/* ── Desktop: side-by-side layout ───────────────────── */
	@media (min-width: 50em) {
		.bc-scene {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
			min-height: 600px;
			padding: 4rem 4rem;
		}

		.bc-headline {
			max-width: 44%;
		}

		.bc-card {
			align-self: auto;
			width: clamp(380px, 48%, 520px);
		}
	}

	/* ── Reduced motion ─────────────────────────────────── */
	@media (prefers-reduced-motion: reduce) {
		.bc-card {
			animation: none;
			transform: perspective(1200px) rotateZ(-8deg);
		}
	}
</style>
