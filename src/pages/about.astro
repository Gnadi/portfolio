---
import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="About | Johannes Gnadlinger" description="About Johannes Gnadlinger">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="Hi!"
				tagline="Thanks for stopping by. A short note on what I work on, and who I am off-duty."
			>
				<img
					width="1600"
					height="1200"
					src="/assets/about.jpg"
					alt="Johannes Gnadlinger"
				/>
			</Hero>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						I started my career building full-stack applications for private banking, gaining end-to-end experience across frontend and backend.
					</p>
					<p>
						For the last four years, I've focused on corporate payment systems — designing and implementing backend services for transaction processing, SEPA flows, and regulated financial infrastructure.
					</p>
					<p>
						I specialize in systems where correctness, reliability, and compliance are critical.
					</p>
				</div>
			</section>

			<section>
				<h2 class="section-title">Personal</h2>
				<div class="content">
					<p>
						Granted, the photo is a bit older ;) But it still describes me well — a cheerful person who loves to travel and meet new people.
					</p>
					<p>
						Growing up in Wels, I moved to Linz several years ago and have been living here with my wife and our little daughter since then.
					</p>
					<p>
						I discovered my passion for programming as a teenager. At sixteen I wrote my first "Hello World"; at twenty I began my career at Raiffeisen Software GmbH, where I continue to learn new things every day.
					</p>
					<p>
						In my free time, I experiment with new technologies on side projects and listen to podcasts on science and politics (exception: Gemischtes Hack).
					</p>
					<p>
						I've managed to quit smoking, and while my success on the tennis court hasn't noticeably improved, I feel better overall.
					</p>
					<p>
						A respectful interaction with others is important to me.
					</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
