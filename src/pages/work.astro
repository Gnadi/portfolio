---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';
import {getLangFromUrl} from "../i18n/utils";
import {defaultLang} from "../i18n/ui";
const lang = getLangFromUrl(Astro.url);

const projects = (await getCollection('work')).map(entry =>{
	const [lang, ...slug] = entry.slug.split('/');
	return { params: { lang, slug: slug.join('/') || undefined }, props: entry };
}).filter(entry => lang == defaultLang ? entry.params.lang != 'de' : entry.params.lang == lang)
	.sort((a, b) => {
		const aPreview = a.props.data.status === 'preview' ? 1 : 0;
		const bPreview = b.props.data.status === 'preview' ? 1 : 0;
		if (aPreview !== bPreview) return aPreview - bPreview;
		return b.props.data.publishDate.valueOf() - a.props.data.publishDate.valueOf();
	});
---

<BaseLayout
	title="Projects | Johannes Gnadlinger"
	description="Side projects by Johannes Gnadlinger"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Projects"
				tagline="Side projects I designed, built, and ship myself."
				align="start"
			/>
			<Grid variant="offset">
				{
					projects.map((project) => (
						<li>
							<PortfolioPreview project={project.props} headingLevel={2} />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>
