---
import { getCollection } from 'astro:content';

// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';


// Component Imports
import CallToAction from '../components/CallToAction.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';

// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Skills from '../components/Skills.astro';
import ContactPreview from "../components/ContactPreview.astro";
import {getLangFromUrl} from "../i18n/utils";
import {defaultLang} from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const projects = (await getCollection('work')).map((entry: any) => {
	const [lang, ...slug] = entry.slug.split('/');
	return { params: { lang, slug: slug.join('/') || undefined }, props: entry };
}).filter((entry: any) => lang == defaultLang ? entry.params.lang != 'de' : entry.params.lang == lang)
	.sort((a: any, b: any) => {
		const aPreview = a.props.data.status === 'preview' ? 1 : 0;
		const bPreview = b.props.data.status === 'preview' ? 1 : 0;
		if (aPreview !== bPreview) return aPreview - bPreview;
		return b.props.data.publishDate.valueOf() - a.props.data.publishDate.valueOf();
	})
	.slice(0, 4);
const contacts = (await getCollection('contact')).slice(0,4);
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Hello, my name is Johannes Gnadlinger"
					tagline="Backend Engineer specializing in corporate payment systems and financial infrastructure. Based in Linz, Austria. 🇦🇹 🇪🇺"
					align="start"
				>
					<div class="roles">
						<a href="https://cv.gnadlinger.me/" target="_blank" aria-label="Open my CV in a new tab">
						<Pill><Icon icon="external" size="1.33em" /> CV</Pill>
						</a>
						<a href="https://blog.gnadlinger.me/" target="_blank" aria-label="Open my blog in a new tab">
							<Pill><Icon icon="external" size="1.33em" /> Blog</Pill>
						</a>
					</div>
				</Hero>

				<Image
					loading="eager"
					alt="Selfie of Johannes Gnadlinger"
					width="480"
					height="620"
					src="/assets/portrait.webp"
				/>
			</header>

			<section class="systems-section stack gap-6 lg:gap-10">
				<header class="section-header stack gap-2 lg:gap-4 systems-header">
					<h2>Areas of Expertise</h2>
					<p>Backend systems for private and corporate banking — payment flows, transaction reliability, operational correctness.</p>
				</header>
				<Skills />
				<p class="tech-line">Primary technologies: Java, Jakarta EE, REST APIs, Angular</p>
			</section>
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Projects</h2>
					<p>Side projects I designed, built, and ship myself.</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project: any) => (
								<li>
									<PortfolioPreview project={project.props} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/work/">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background bg-variant">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Find Me / Contact Me</h2>
					<p>Find me on Stack Overflow, GitHub, and LinkedIn.</p>
				</header>

				<div class="gallery">
					<Grid variant="small">
						{
							contacts.map((contact: any) => (
								<li class="mention-card">
									<ContactPreview contact={contact} />
								</li>
							))
						}
					</Grid>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}
	@media (max-width: 50em) {
		.roles {
			display: flex;
			justify-content: space-around;
		}
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.webp') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h2 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h2 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ====================================================== */

	.mention-card {
		display: flex;
		height: 7rem;
		justify-content: center;
		align-items: center;
		text-align: center;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		color: var(--gray-300);
		background: #f3f4f7;
		box-shadow: var(--shadow-sm);
	}

	@media (min-width: 50em) {
		.mention-card {
			border-radius: 1.5rem;
			height: 9.5rem;
		}
	}

	.systems-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		margin-inline: auto;
	}

	.systems-header h2 {
		font-size: var(--text-2xl);
	}

	.tech-line {
		text-align: center;
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	@media (min-width: 50em) {
		.systems-header h2 {
			font-size: var(--text-4xl);
		}

		.tech-line {
			font-size: var(--text-md);
		}
	}
</style>
